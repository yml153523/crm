{
  "apps": [
    {
      "name": "crm-server",
      "script": "server.js",
      "cwd": "/root/crm/server",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "production",
        "PORT": 5011
      },
      "error_log": "/var/log/crm-server-error.log",
      "out_log": "/var/log/crm-server-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss"
    }
  ]
}
